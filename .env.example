# Database connection details - Copy from .env.local on the Vercel dashboard
# For more information, visit: https://nextjs.org/learn/dashboard-app/setting-up-your-database#create-a-postgres-database

# PostgreSQL connection URL
POSTGRES_URL= 

# Prisma connection URL for PostgreSQL
POSTGRES_PRISMA_URL=
# Database Url
DATABASE_URL=

# Secret key for authentication (generated using `openssl rand -base64 32`)
AUTH_SECRET=

# Authentication URL for local development
# AUTH_URL=http://localhost:3001/api/auth

# Google OAuth Keys
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=